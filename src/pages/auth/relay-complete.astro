---
import { exchangeCodeForTokens } from '@/lib/tesla/auth';
import { saveUserTokens, saveUserProfile } from '@/lib/db';
import { createUserSession } from '@/lib/session';
import { getUserMe } from '@/lib/tesla/vehicles';
import { isRelayConfigured } from '@/env';

if (!isRelayConfigured()) {
  return Astro.redirect('/setup');
}

const code = Astro.url.searchParams.get('code');
const state = Astro.url.searchParams.get('state');
const errorParam = Astro.url.searchParams.get('error');
const savedState = Astro.cookies.get('oauth_state')?.value;

if (errorParam) {
  return Astro.redirect(`/auth/login?error=${encodeURIComponent(errorParam)}`);
}

if (!code || !state || state !== savedState) {
  return Astro.redirect('/auth/login?error=invalid_state');
}

try {
  await exchangeCodeForTokens(code);
  createUserSession(Astro.cookies);

  try {
    const me = await getUserMe();
    saveUserProfile({ email: me.email, fullName: me.full_name });
  } catch {
    // non-critical
  }

  Astro.cookies.delete('oauth_state', { path: '/' });
  return Astro.redirect('/garage');
} catch (e) {
  const message = e instanceof Error ? e.message : 'auth_failed';
  return Astro.redirect(`/auth/login?error=${encodeURIComponent(message)}`);
}
---
