---
import AppLayout from '@/layouts/AppLayout.astro';
import { getDeveloperConfig } from '@/lib/db';
import { buildAuthorizeUrl } from '@/lib/tesla/auth';
import { generateSessionId } from '@/lib/crypto';
import { isRelayConfigured } from '@/env';

const config = getDeveloperConfig();
if (!config) {
  return Astro.redirect('/setup');
}

if (!isRelayConfigured()) {
  return Astro.redirect('/setup');
}

const errorParam = Astro.url.searchParams.get('error');
const state = generateSessionId();
const authorizeUrl = buildAuthorizeUrl(state);

Astro.cookies.set('oauth_state', state, {
  httpOnly: true,
  secure: import.meta.env.PROD || process.env.ENABLE_HTTPS !== 'false',
  sameSite: 'lax',
  path: '/',
  maxAge: 600,
});
---

<AppLayout title="Sign In — Tesla Desktop" showNav={false}>
  <div class="flex min-h-[calc(100vh-0px)] flex-col items-center justify-center px-6">
    <div class="w-full max-w-md text-center">
      <img src="/imgs/logo_white.png" alt="Tesla" class="mx-auto mb-8 h-6" />
      <h1 class="mb-3 text-2xl font-semibold">Sign in with Tesla</h1>
      <p class="mb-8 text-tesla-muted">
        Connect your Tesla account to view and control your vehicles.
      </p>
      {errorParam && (
        <div class="mb-6 rounded-lg border border-tesla-red/50 bg-tesla-red/10 px-4 py-3 text-sm text-tesla-red">
          {errorParam}
        </div>
      )}
      <a href={authorizeUrl} class="tesla-btn-primary w-full">
        Sign In
      </a>
      <p class="mt-6 text-xs text-tesla-muted">
        You'll be redirected to Tesla, then back to localhost via the relay.
      </p>
    </div>
  </div>
</AppLayout>
