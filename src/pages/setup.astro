---
import AppLayout from '@/layouts/AppLayout.astro';
import SetupWizard from '@/components/setup/SetupWizard';
import { getEnv, isRelayMode } from '@/env';
import { getDeveloperConfig } from '@/lib/db';
import { getPublicKeyCheckUrl, getAppOrigin } from '@/lib/tesla/partner';
import { ensureKeyPair, getPublicKeyContent } from '@/lib/keys';
import { getStoredRelayInstance } from '@/lib/relay';

ensureKeyPair();
const config = getDeveloperConfig();
const publicKey = getPublicKeyContent();
const relayMode = isRelayMode();
const relayInstance = relayMode ? getStoredRelayInstance() : null;
const appOrigin = config ? getAppOrigin(config) : getEnv().redirectUri.replace(/\/auth\/callback$/, '');
const publicKeyUrl = relayInstance?.publicKeyUrl ?? (config ? getPublicKeyCheckUrl(config) : `${appOrigin}/.well-known/appspecific/com.tesla.3p.public-key.pem`);
---

<AppLayout title="Setup — Tesla Desktop" showNav={false}>
  <div class="mx-auto max-w-content px-6 py-12">
    <SetupWizard
      client:load
      initialConfig={config}
      publicKey={publicKey}
      publicKeyUrl={publicKeyUrl}
      appOrigin={appOrigin}
      relayMode={relayMode}
      relayInstanceId={relayInstance?.instanceId ?? null}
    />
  </div>
</AppLayout>
