---
import AppLayout from '@/layouts/AppLayout.astro';
import VehicleControls from '@/components/vehicle/VehicleControls';

const { vin } = Astro.params;
if (!vin) return Astro.redirect('/garage');
---

<AppLayout title="Controls — Tesla Desktop">
  <div class="mx-auto max-w-content px-6 py-8">
    <VehicleControls client:load vin={vin} />
  </div>
</AppLayout>
