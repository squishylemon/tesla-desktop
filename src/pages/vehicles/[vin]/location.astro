---
import AppLayout from '@/layouts/AppLayout.astro';
import VehicleMap from '@/components/vehicle/VehicleMap';
import { getCachedVehicleData } from '@/lib/tesla/vehicles';

const { vin } = Astro.params;
if (!vin) return Astro.redirect('/garage');

const cached = getCachedVehicleData(vin);
const name = cached?.data?.display_name ?? 'My Tesla';
---

<AppLayout title="Location — Tesla Desktop">
  <div class="mx-auto max-w-content px-6 py-8">
    <VehicleMap client:only="react" vin={vin} name={name} />
  </div>
</AppLayout>
