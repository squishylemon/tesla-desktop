# =============================================================================
# Tesla Desktop Relay — cloud operator config (relay/.env)
# Copy:  cp relay/.env.example relay/.env
# Start: docker compose --profile cloudsetup up --build -d
# =============================================================================

# --- Who can register new home instances ---
# * = anyone on the internet can use your relay domain
# Or comma-separated IPv4 addresses / CIDR blocks (home IP only, etc.)
ALLOWED_IPS=*

# --- Your domain ---
RELAY_BASE_DOMAIN=tesla-desktop.example.com
RELAY_OAUTH_HOST=auth.tesla-desktop.example.com

# --- Tesla Fleet API app (maintainer-owned; shared by home installs) ---
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REGION=NA

# --- Cloudflare DNS (auto-creates {instanceId}.yourdomain.com per home install) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
RELAY_DNS_TYPE=A
RELAY_DNS_TARGET=
RELAY_DNS_PROXIED=true

# --- Instance lifecycle ---
# Delete DNS + instance data when no heartbeat for this many days
RELAY_INACTIVITY_DAYS=30
# How often the cleanup job runs (hours)
RELAY_CLEANUP_INTERVAL_HOURS=6

# --- Optional extra lock on registration (in addition to ALLOWED_IPS) ---
RELAY_BOOTSTRAP_SECRET=

# --- Server ---
HOST=0.0.0.0
PORT=8443
DATA_DIR=/data
RELAY_PORT=8443
