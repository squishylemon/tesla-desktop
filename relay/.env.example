# Tesla Desktop Relay — cloud operator
# cp relay/.env.example relay/.env
# npm run cloudsetup

# Who can register new home instances
# * = anyone | single IP | comma-separated IPs or CIDR
ALLOWED_IPS=*

# Your domain
RELAY_BASE_DOMAIN=tesla-desktop.example.com
RELAY_OAUTH_HOST=auth.tesla-desktop.example.com

# Cloudflare: auto-creates {instanceId}.RELAY_BASE_DOMAIN per home install
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
RELAY_DNS_TYPE=A
RELAY_DNS_TARGET=
RELAY_DNS_PROXIED=true

# Remove instances with no heartbeat after this many days
RELAY_INACTIVITY_DAYS=30
# How often the cleanup job runs (hours)
RELAY_CLEANUP_INTERVAL_HOURS=6

# Optional: extra secret for POST /api/v1/instances
RELAY_BOOTSTRAP_SECRET=

# Relay server
HOST=0.0.0.0
PORT=8443
DATA_DIR=/data
RELAY_PORT=8443
