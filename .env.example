# Tesla Desktop — home install
# cp .env.example .env
# docker compose up --build

# Host port mapping (docker compose only)
APP_PORT=4321

# App server
HOST=0.0.0.0
PORT=4321
DATA_DIR=./data
ENABLE_HTTPS=true

# Encrypts OAuth tokens at rest (generate: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# Relay (required) — OAuth and partner registration use this domain
RELAY_API_URL=https://auth.tesla-desktop.example.com
# RELAY_BOOTSTRAP_SECRET=

# TLS certificate CN for localhost (leave as-is)
TESLA_TLS_HOSTNAME=localhost

# Vehicle command proxy (Docker sidecar — leave as-is for docker compose)
VEHICLE_COMMAND_PROXY_URL=https://vehicle-command:4443
VEHICLE_COMMAND_PROXY_CA=/data/tls-cert.pem

# Cloud relay operator only (docker compose --profile cloudsetup)
# RELAY_PORT=8443
