# Server
HOST=0.0.0.0
PORT=4321
DATA_DIR=./data
ENABLE_HTTPS=true

# Tesla OAuth (configured via /setup wizard, or set here)
# Hostname for partner registration + virtual key pairing (must be reachable from internet, not localhost)
TESLA_DOMAIN=localhost
TESLA_TLS_HOSTNAME=localhost
# TESLA_REDIRECT_URI=https://localhost:4321/auth/callback

# Encryption key for tokens at rest (32+ chars; generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# Vehicle command proxy (Docker sidecar)
VEHICLE_COMMAND_PROXY_URL=https://vehicle-command:4443
VEHICLE_COMMAND_PROXY_CA=/data/tls-cert.pem

# --- Relay mode (Option B: shared maintainer domain) ---
# When set, OAuth + partner registration use the relay; UI stays on localhost:4321
# RELAY_API_URL=https://auth.tesla-desktop.example.com
# RELAY_BOOTSTRAP_SECRET=
# RELAY_SHARED_CLIENT_ID=your-fleet-api-client-id
# RELAY_SHARED_CLIENT_SECRET=your-fleet-api-client-secret
# RELAY_SHARED_REGION=NA
